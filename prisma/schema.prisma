generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Report {
  id         BigInt    @id @default(autoincrement())
  nama       String
  jenis      String
  modus      String
  lokasi     String    @default("")
  kontak     String    @default("")
  scam_score Int       @default(0)
  upvotes    Int       @default(0)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  comments   Comment[]

  @@map("reports")
}

model Comment {
  id         BigInt   @id @default(autoincrement())
  report_id  BigInt
  isi        String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  report     Report   @relation(fields: [report_id], references: [id], onDelete: Cascade)

  @@index([report_id])
  @@map("comments")
}

model LedgerBook {
  id           String        @id
  nama_usaha   String        @default("Usaha Saya")
  created_at   DateTime      @default(now()) @db.Timestamptz(6)
  transactions Transaction[]

  @@map("ledger_books")
}

model Transaction {
  id          BigInt     @id @default(autoincrement())
  book_id     String
  tanggal     DateTime   @db.Date
  keterangan  String
  kategori    String
  jenis       String
  nominal     BigInt
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  ledger_book LedgerBook @relation(fields: [book_id], references: [id], onDelete: Cascade)

  @@index([book_id])
  @@index([tanggal(sort: Desc)])
  @@map("transactions")
}
